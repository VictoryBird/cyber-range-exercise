FROM node:20-slim AS build
WORKDIR /app
COPY assets/03_complaint_intake/src/frontend/package.json .
RUN npm install
COPY assets/03_complaint_intake/src/frontend/ .
RUN npm run build

FROM nginx:alpine
COPY --from=build /app/dist /usr/share/nginx/html
COPY docker/complaint-nginx-frontend.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
