# ============================================================
# AI 어시스턴트 환경 변수 (.env)
# 자산 07 — 192.168.100.13 (ai.mois.local)
# ============================================================

# --- Ollama ---
OLLAMA_URL=http://192.168.100.13:11434
OLLAMA_HOST=0.0.0.0

# --- OpenWebUI ---
OPENWEBUI_URL=http://192.168.100.13:3000
OPENWEBUI_PORT=3000
OPENWEBUI_SECRET_KEY=changeme-openwebui-secret-key

# --- Nextcloud WebDAV (문서 수집 소스) ---
NEXTCLOUD_URL=https://192.168.100.12
NEXTCLOUD_WEBDAV_PATH=/remote.php/dav/files/ai-service/공유문서/
NEXTCLOUD_USERNAME=ai-service
NEXTCLOUD_PASSWORD=AiSvc2024!@#

# --- LDAP / AD 인증 ---
LDAP_SERVER=ldap://192.168.100.10:389
LDAP_BASE_DN=dc=mois,dc=local
LDAP_BIND_DN=cn=ai-service,ou=ServiceAccounts,dc=mois,dc=local
LDAP_BIND_PASSWORD=AiSvc2024!@#

# --- ChromaDB ---
CHROMA_PERSIST_DIR=/opt/ai-assistant/data/chromadb
CHROMA_COLLECTION=mois_documents

# --- RAG 설정 ---
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.3
EMBEDDING_MODEL=nomic-embed-text
LLM_MODEL=llama3
