[Unit]
Description=Minwon Intake API (Uvicorn)
After=network.target

[Service]
Type=simple
User=minwon
Group=minwon
WorkingDirectory=/opt/minwon/backend
EnvironmentFile=/opt/minwon/.env
ExecStart=/opt/minwon/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000 --workers 2
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
