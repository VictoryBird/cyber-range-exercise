# ── D2 VPN 게이트웨이 (211.57.64.11) ──────────────────────────
# 사이버 훈련 전용 — 실제 운영 환경 사용 금지

# ── 서버 기본 설정 ──
VPN_HOST=211.57.64.11
VPN_HOSTNAME=mil-vpn-gw
VPN_DOMAIN=vpn.mnd.valdoria.mil
VPN_PORT_UDP=1194
VPN_PORT_TCP=443
VPN_ADMIN_PORT=943
VPN_PROTO=udp

# ── 네트워크 인터페이스 ──
VPN_LISTEN_IF=ens192
VPN_TUN_IF=tun0

# ── 클라이언트 IP 풀 (172.20.100.0/24) ──
VPN_POOL_NETWORK=172.20.100.0
VPN_POOL_NETMASK=255.255.255.0
VPN_POOL_START=172.20.100.100
VPN_POOL_END=172.20.100.200
VPN_SERVER_TUN_IP=172.20.100.1

# ── 라우팅 ──
VPN_ROUTE_ALLOWED=192.168.120.0/24
VPN_DNS_PUSH=192.168.120.1

# ── 인증 ──
# [취약점] VULN-D2-01: MFA 미적용 — 패스워드 단독 인증
VPN_AUTH_TYPE=local
VPN_MFA_ENABLED=false

# ── 세션 ──
VPN_SESSION_TIMEOUT=86400

# ── 인증서 (자동 생성) ──
VPN_CA_CN=MND-VPN-CA
VPN_SERVER_CN=vpn.mnd.valdoria.mil
VPN_CERT_DIR=/etc/openvpn/server/certs
VPN_KEY_SIZE=2048

# ── 관리자 ──
VPN_ADMIN_USER=openvpn
VPN_ADMIN_PASS=VPN@dmin2024!

# ── Docker 테스트용 ──
CONTAINER_NAME=d2-vpn-gateway
