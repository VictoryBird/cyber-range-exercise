# ============================================================
# 패치 관리 서버 환경변수 (.env)
# 대상: 192.168.120.10 / update.mnd.local
# ============================================================

PATCH_SERVER_HOST=192.168.120.10
HTTP_PORT=80
UPDATES_DIR=/var/www/update-server/updates
ADMIN_DIR=/var/www/update-server/admin
LOG_DIR=/var/www/update-server/logs
MAX_UPLOAD_SIZE=104857600
