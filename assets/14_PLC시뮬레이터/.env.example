# PLC 시뮬레이터 환경 변수
# 대상: 192.168.201.11 (OT 존)

# 서버 설정
PLC_HOST=0.0.0.0
PLC_PORT=5000

# 센서 범위 설정 (기본값)
TEMP_MIN=20.0
TEMP_MAX=30.0
PRESSURE_MIN=95.0
PRESSURE_MAX=105.0
FLOW_RATE_MIN=120.0
FLOW_RATE_MAX=180.0
POWER_MIN=220.0
POWER_MAX=240.0

# 시뮬레이션 설정
UPDATE_INTERVAL=1.0
HISTORY_MAXLEN=3600

# Gunicorn 설정
GUNICORN_WORKERS=2
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=120
