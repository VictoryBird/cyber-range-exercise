# ── 외부 포털 서버 환경변수 ──────────────────────────────────
# 파일명: .env
# 위치: /opt/mois-portal/.env

# 서버 설정
APP_NAME=MOIS Portal
VERSION=1.2.0
ENVIRONMENT=production
DEBUG=false
HOST=0.0.0.0
PORT=8000

# 도메인
DOMAIN=www.mois.valdoria.gov
ALLOWED_ORIGINS=["https://www.mois.valdoria.gov","http://203.238.140.10","http://localhost"]

# 데이터베이스 (원격 DB 서버)
# [취약 설정] 하드코딩된 크리덴셜
DB_HOST=192.168.100.20
DB_PORT=5432
DB_NAME=mois_portal
DB_USER=portal_app
DB_PASSWORD=P0rtal#DB@2026!

# JWT 인증
# [취약 설정] 약한 시크릿 키
JWT_SECRET=valdoria-mois-jwt-secret-key-2026
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# 로깅
LOG_LEVEL=INFO
LOG_FILE=/var/log/mois-portal/app.log
