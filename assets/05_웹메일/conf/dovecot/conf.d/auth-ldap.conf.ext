# ============================================================
# Dovecot LDAP 인증 설정 (AD 서버 연동)
# ============================================================

passdb {
  driver = ldap
  args = /etc/dovecot/dovecot-ldap.conf.ext
}

userdb {
  driver = static
  args = uid=5000 gid=5000 home=/var/mail/vhosts/%d/%n
}
