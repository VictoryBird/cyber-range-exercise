[Unit]
Description=Document Storage Server (FastAPI)
After=network.target postgresql.service

[Service]
Type=simple
User=docstorage
Group=docstorage
WorkingDirectory=/opt/docstorage
EnvironmentFile=/opt/docstorage/.env
ExecStart=/opt/docstorage/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
