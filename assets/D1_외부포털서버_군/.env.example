# ============================================================
# D1 외부 포털 서버 (Military External Portal) — 환경변수
# Asset: D1 | IP: 211.57.64.10 | OS: Rocky Linux 9
# ============================================================

# --- Domain ---
DOMAIN=www.mnd.valdoria.mil
SERVER_IP=211.57.64.10

# --- Tomcat ---
TOMCAT_VERSION=9.0.62
TOMCAT_HOME=/opt/tomcat
TOMCAT_HTTP_PORT=8080
TOMCAT_SHUTDOWN_PORT=8005
JAVA_HOME=/usr/lib/jvm/java-11-openjdk

# --- PostgreSQL ---
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=mnd_portal
DB_USER=portal
DB_PASSWORD=Portal@DB2024!

# --- Nginx ---
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
SSL_CERT_PATH=/etc/nginx/ssl/mnd_valdoria_mil.crt
SSL_KEY_PATH=/etc/nginx/ssl/mnd_valdoria_mil.key

# --- Application ---
APP_NAME=mnd-portal
WAR_NAME=ROOT.war
STATIC_ROOT=/var/www/mnd-portal/static
